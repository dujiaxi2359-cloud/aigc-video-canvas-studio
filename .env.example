# Frontend / intranet sharing
# Dev on this machine can leave it empty only when using a same-origin proxy.
# For coworkers on the same WiFi/LAN, set this to your computer's LAN backend URL.
VITE_API_BASE_URL=http://你的内网IP:4000

# Backend / intranet sharing
HOST=0.0.0.0
PORT=4000
BACKEND_PUBLIC_BASE_URL=http://你的内网IP:4000
FRONTEND_ORIGIN=http://你的内网IP:3001

APP_SECRET=replace-with-a-long-random-secret
AUTH_SECRET=replace-with-a-different-long-random-secret
APP_BASE_URL=http://你的内网IP:3001
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# Only for automated local tests. Keep false for real users; never works in production.
AUTH_ALLOW_MOCK_EMAIL=false

# Optional named fallback providers. Login email tries SMTP_* first, then SMTP_QQ_*,
# SMTP_GMAIL_*, and SMTP_FALLBACK_* until one succeeds.
#
# QQ Mail example:
# SMTP_QQ_HOST=smtp.qq.com
# SMTP_QQ_PORT=465
# SMTP_QQ_USER=your-number@qq.com
# SMTP_QQ_PASS=QQ Mail SMTP authorization code (not the QQ password)
# SMTP_QQ_FROM="AIGCNONG <your-number@qq.com>"
#
# Gmail example:
# SMTP_GMAIL_HOST=smtp.gmail.com
# SMTP_GMAIL_PORT=587
# SMTP_GMAIL_USER=your-account@gmail.com
# SMTP_GMAIL_PASS=Google 16-character app password (not the normal account password)
# SMTP_GMAIL_FROM="AIGCNONG <your-account@gmail.com>"
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_INVITE_CODE=AIGCNONG-ACCESS
INITIAL_FREE_CREDITS=100
DATABASE_PATH=./data/app.sqlite

# Files
UPLOAD_DIR=./uploads
UPLOADS_DIR=./uploads
PUBLIC_UPLOADS_BASE_URL=http://你的内网IP:4000/uploads

FORCE_MOCK_GENERATION=false
ALLOW_MOCK_GENERATION=false
AZURE_OPENAI_API_VERSION=preview

# Optional: auto-upload local image assets to Alibaba Cloud OSS when a provider
# requires a cloud-readable image URL, such as Alibaba Wan image-to-video.
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_REGION=oss-cn-beijing
OSS_ENDPOINT=
OSS_PUBLIC_BASE_URL=
OSS_SIGNED_URL_EXPIRES=3600
# private = safer default, system returns signed temporary URLs.
# public-read = system returns OSS_PUBLIC_BASE_URL/object-key when configured.
OSS_OBJECT_ACL=private

# Backend network mode:
# off = use system routing / VPN TUN mode
# env = read HTTP_PROXY / HTTPS_PROXY / ALL_PROXY on startup
# manual = use MANUAL_PROXY_URL
# auto = prefer MANUAL_PROXY_URL, fallback to env proxy, otherwise off/TUN
# Recommended for 0dcloud local HTTP proxy. Use auto if your proxy port changes often.
PROXY_MODE=auto
MANUAL_PROXY_URL=
# Example:
# PROXY_MODE=manual
# MANUAL_PROXY_URL=http://127.0.0.1:17891
HTTP_PROXY=
HTTPS_PROXY=
ALL_PROXY=
NO_PROXY=localhost,127.0.0.1

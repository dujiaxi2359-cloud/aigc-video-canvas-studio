# Leave empty to use the same origin as the current page.
VITE_API_BASE_URL=

PORT=4000
APP_SECRET=replace-with-a-long-random-secret
DATABASE_PATH=./data/app.sqlite
UPLOAD_DIR=./uploads
FORCE_MOCK_GENERATION=false
ALLOW_MOCK_GENERATION=false
BACKEND_PUBLIC_BASE_URL=
AZURE_OPENAI_API_VERSION=preview

# Optional: auto-upload local image assets to Alibaba Cloud OSS when a provider
# requires a cloud-readable image URL, such as Alibaba Wan image-to-video.
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_REGION=oss-cn-beijing
OSS_ENDPOINT=
OSS_PUBLIC_BASE_URL=
OSS_SIGNED_URL_EXPIRES=3600
# private = safer default, system returns signed temporary URLs.
# public-read = system returns OSS_PUBLIC_BASE_URL/object-key when configured.
OSS_OBJECT_ACL=private

# Backend network mode:
# off = use system routing / VPN TUN mode
# env = read HTTP_PROXY / HTTPS_PROXY / ALL_PROXY on startup
# manual = use MANUAL_PROXY_URL
# auto = prefer MANUAL_PROXY_URL, fallback to env proxy, otherwise off/TUN
PROXY_MODE=auto
MANUAL_PROXY_URL=
HTTP_PROXY=
HTTPS_PROXY=
ALL_PROXY=
NO_PROXY=localhost,127.0.0.1

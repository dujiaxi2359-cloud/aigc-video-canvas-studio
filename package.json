{
  "name": "aigc-video-canvas-studio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n photos,video,server -c green,cyan,magenta \"npm run dev --prefix photo-app\" \"npm run dev --workspace client\" \"npm run dev --workspace server\"",
    "build": "npm run build --prefix photo-app && npm run build --workspace client && npm run build --workspace server",
    "tunnel": "node scripts/start-cloudflare-tunnel.cjs",
    "tunnel:http2": "node scripts/start-cloudflare-tunnel.cjs --protocol http2",
    "typecheck": "npm run typecheck --workspace client && npm run typecheck --workspace server",
    "test:email": "npm run test:email --workspace server --",
    "test:video-official": "npm run test:video-official --workspace server",
    "test:quality-parity": "npm run test:quality-parity --workspace server",
    "test:official-video-categories": "npm run test:official-video-categories --workspace server",
    "test:veo-operation-parser": "npm run test:veo-operation-parser --workspace server",
    "test:video-provider-adapters": "npm run test:video-provider-adapters --workspace server",
    "test:azure-gpt-image-config": "npm run test:azure-gpt-image-config --workspace server",
    "test:image-asset-compat": "npm run test:image-asset-compat --workspace server",
    "test:image-response-extractor": "npm run test:image-response-extractor --workspace server",
    "test:grsai-image-adapter": "npx tsx server/src/scripts/testGrsaiImageAdapter.ts",
    "test:video-result-extractor": "npx tsx server/src/scripts/testVideoResultExtractor.ts",
    "test:video-task-finalizer": "npx tsx server/src/scripts/testVideoTaskFinalizer.ts",
    "test:midjourney-image-adapter": "npm run test:midjourney-image-adapter --workspace server",
    "test:asset-access-token": "npm run test:asset-access-token --workspace server",
    "test:model-capability-classification": "npm run test:model-capability-classification --workspace server",
    "test:veo-capabilities": "npm run test:veo-capabilities --workspace server"
  },
  "workspaces": [
    "client",
    "server"
  ],
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
